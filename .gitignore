aider_stdlib_map.md

# Generated by Cargo
# will have compiled files and executables
debug/
target/

# Cargo.lock IS committed (deliberately, since freenet/river#2776 A1).
# River builds byte-reproducible contract/delegate WASM whose bytes define the
# room-contract and chat-delegate keys (key = BLAKE3(BLAKE3(wasm) || params)).
# A committed lock + the pinned toolchain (rust-toolchain.toml) makes those
# builds deterministic, so a rebuild no longer silently re-keys the contract via
# a drifted transitive dependency. Build the key-defining WASMs with `--locked`
# (see scripts/sync-wasm.sh and the build-room-contract / build-chat-delegate
# tasks in Makefile.toml). Do NOT re-add Cargo.lock here.

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# RustRover
#  JetBrains specific template is maintained in a separate JetBrains.gitignore that can
#  be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
#  and can be added to the global gitignore or merged into this file.  For a more nuclear
#  option (not recommended) you can uncomment the following to ignore the entire idea folder.
.idea/
.aider*
.aider.chat.history.md
.env

# Keep published contract files
!published-contract/

# Test contract files (generated locally, not committed)
test-contract/

# Playwright MCP artifacts
.playwright-mcp/

# Node modules (Playwright tests, Tailwind build)
node_modules/

# Playwright test results
ui/tests/test-results/

# Manual e2e test screenshots (see #244 review feedback)
/dm-*.png

# Web-container version-counter rollback snapshot. Created by
# `cargo make sign-webapp` BEFORE bumping the counter; removed on
# successful publish, or moved back over the counter on failure.
# Should never appear in commits.
/published-contract/contract-version.txt.prev

# Syncthing in-flight transfer files (`.syncthing.<name>.tmp` are
# created by the syncthing daemon while a file is being received).
**/.syncthing.*.tmp
